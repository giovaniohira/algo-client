{
  "name": "algo-client",
  "version": "0.2.0",
  "description": "Unofficial desktop client for LeetCode — Monaco editor, local catalog, run/submit",
  "author": "Giovani Ohira",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/giovaniohira/algo-client.git"
  },
  "homepage": "https://github.com/giovaniohira/algo-client#readme",
  "bugs": {
    "url": "https://github.com/giovaniohira/algo-client/issues"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "check": "tsx scripts/adapter-check.ts",
    "sync-problems": "tsx scripts/sync-problems.ts",
    "export-logos": "tsx scripts/export-logos.ts",
    "dist": "npm run export-logos && npm run build && electron-builder",
    "dist:win": "npm run export-logos && npm run build && electron-builder --win --publish never"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "leetcode-query": "^2.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.algoclient.desktop",
    "productName": "Algo Client",
    "electronLanguages": [
      "en-US"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "data/problems",
        "to": "data/problems",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "icon": "build/icon.png",
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-setup.${ext}",
      "signAndEditExecutable": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "giovaniohira",
      "repo": "algo-client"
    }
  }
}
